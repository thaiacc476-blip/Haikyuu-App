```
[app]
# App နာမည်
title = Haikyuu

# App ID (Package name)
package.name = haikyuubrowser
package.domain = com.master

# VERSION (ဒါက အသစ်ထည့်ရမယ့် အချက်ပါ)
version = 0.1

# SOURCE DIR (ဒါကလည်း အသစ်ထည့်ရမယ့် အချက်ပါ)
source.dir = .

# သုံးထားတဲ့ ဖိုင်အမျိုးအစားများ
source.include_exts = py,png,jpg,kv,atlas

# App Icon
icon.filename = haikyuu.jpg

# လိုအပ်သော Libraries
requirements = python3,kivy==2.2.1,kivymd==1.1.1,pillow,urllib3

# Screen Orientation
orientation = portrait

# Android Permissions
android.permissions = INTERNET

# Full Screen (ဒါကလည်း အသစ်ထည့်ရမယ့် အချက်ပါ)
android.fullscreen = 1
```